# =============================================================================
# answers.env.example — headless answers for main.sh --non-interactive
# =============================================================================
# Copy this file, fill in values, then:
#   sudo ./main.sh --answers /root/answers.env --non-interactive
#
# main.sh pre-seeds its ephemeral state from this file at startup. During
# --non-interactive runs, modules use seeded values and do not prompt.
# The ephemeral state file at /run/cloud-init-scripts/state.env is deleted
# on exit; values are written to their canonical config files (sshd_config.d,
# ufw, /etc/rancher/rke2/..., etc.) by each module's run function.
#
# Keys use shell quoting rules: KEY="value" or KEY='value'. One per line.
# =============================================================================

# --- Profile & networks (10, 15) ---------------------------------------------
PROFILE="k8s"                   # k8s | docker | bare
NET_PUBLIC_IFACE="eth0"
NET_PUBLIC_IP="203.0.113.10"
NET_HAS_PRIVATE="yes"           # yes | no
NET_PRIVATE_IFACE="enp7s0"
NET_PRIVATE_IP="10.0.0.12"
NET_PRIVATE_CIDR="10.0.0.0/24"

# --- OS hardening (20-29) ----------------------------------------------------
HOSTNAME_FQDN="node01.example.com"
USER_NAME="andrei"               # blank = do not create a sudo user
USER_SSH_KEY="ssh-ed25519 AAAA... your@host"
SSH_PORT="22"
SSH_KEYGEN_ENABLED="yes"         # generate host-side Ed25519 for GitHub/peer access
SSH_KEYGEN_ALSO_ROOT="no"
SSH_KEYGEN_PEER_PUBKEYS=""       # newline-separated peer pubkeys (optional)
FIREWALL_OPEN_HTTP="no"          # k8s default; "yes" for docker/bare
UNATTENDED_ENABLED="yes"

# --- Host security (30-34) ---------------------------------------------------
SECURITY_TOOL="crowdsec"         # fail2ban | crowdsec
CROWDSEC_ENROLL_KEY=""           # optional, from https://app.crowdsec.net
TAILSCALE_ENABLED="no"
UBUNTU_PRO_ENABLED="no"
UBUNTU_PRO_TOKEN=""

# --- Docker profile (40-41) --------------------------------------------------
DOCKER_ADD_USER="yes"            # add USER_NAME to the docker group

# --- Web server (50-53) — docker / bare profiles -----------------------------
WEBSERVER_KIND="none"            # nginx | apache | openresty | none
WEBSERVER_DOMAIN=""
WEBSERVER_EMAIL=""

# --- RKE2 (60-65) — k8s profile ---------------------------------------------
RKE2_ROLE="bootstrap"            # bootstrap | server | worker
RKE2_NODE_IP="10.0.0.12"
RKE2_TOKEN=""                    # paste existing; bootstrap auto-generates if empty
RKE2_SERVER_URL=""               # https://10.0.0.8:6443 (joining nodes only)
RKE2_CNI="calico"                # calico | cilium | canal
RKE2_WIREGUARD="no"
RKE2_TLS_SANS=""                 # space-separated extra SANs
RKE2_POD_CIDR="10.42.0.0/16"
RKE2_SVC_CIDR="10.43.0.0/16"
RKE2_ETCD_METRICS="false"
RKE2_AUDIT_LOG="yes"
RKE2_CHANNEL=""                  # "" = stable; or "latest", "v1.28", etc.

# --- Platform stack (70-79) — k8s profile -----------------------------------
PLATFORM_LOCAL_PATH="yes"
PLATFORM_INGRESS="yes"
PLATFORM_INGRESS_LB_IP="10.0.0.8"
PLATFORM_CERTMGR="yes"
PLATFORM_CERT_EMAIL="ops@example.com"
PLATFORM_CERT_DOMAIN="example.com"
PLATFORM_CERT_ISSUERS="both"     # staging | both | prod
PLATFORM_MONITORING="yes"
PLATFORM_GRAFANA_PASSWORD=""     # leave blank to auto-generate
PLATFORM_GRAFANA_HOST="grafana.example.com"
PLATFORM_GRAFANA_ISSUER="letsencrypt-staging"
PLATFORM_PROM_RETENTION="30d"
PLATFORM_PROM_STORAGE="50Gi"
PLATFORM_AM_STORAGE="5Gi"
PLATFORM_LOGGING="yes"
PLATFORM_LOKI_RETENTION="336h"
PLATFORM_LOKI_STORAGE="50Gi"
PLATFORM_CROWDSEC="no"
CROWDSEC_BOUNCER_KEY=""          # auto-generated if blank
PLATFORM_RANCHER="no"
PLATFORM_RANCHER_HOST="rancher.example.com"
PLATFORM_RANCHER_ISSUER="letsencrypt-staging"
PLATFORM_RANCHER_PASSWORD=""     # leave blank to auto-generate
PLATFORM_RANCHER_REPLICAS="3"
